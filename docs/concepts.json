  {
    "level": "intermediate",
    "category": "검색",
    "items": [
      {
        "title": "grep — 텍스트 검색",
        "summary": "파일 내용에서 특정 텍스트 패턴을 검색한다",
        "syntax": "grep [옵션] \"패턴\" 파일/경로",
        "options": [
          { "flag": "-i", "desc": "ignore-case — 대소문자 구분 안 함" },
          { "flag": "-n", "desc": "number — 줄번호도 같이 출력" },
          { "flag": "-r", "desc": "recursive — 하위 폴더까지 검색" },
          { "flag": "-c", "desc": "count — 매칭된 줄 수만 출력" },
          { "flag": "-v", "desc": "invert — 패턴이 없는 줄만 출력 (제외)" },
          { "flag": "--include", "desc": "특정 파일 유형에서만 검색" }
        ],
        "examples": [
          { "code": "grep \"에러\" log.txt", "desc": "log.txt에서 '에러' 포함된 줄 출력" },
          { "code": "grep -rn \"TODO\" ./", "desc": "모든 파일에서 TODO 검색 + 줄번호" },
          { "code": "grep -ri \"error\" logs/", "desc": "대소문자 무시 + 재귀 검색" },
          { "code": "grep -rn \"def train\" --include=\"*.py\" ./", "desc": ".py 파일에서만 검색" }
        ],
        "tip": "grep -v로 특정 패턴을 제외할 수 있다 (예: grep -v 'DEBUG' log.txt)"
      },
      {
        "title": "find — 파일/폴더 찾기",
        "summary": "조건에 맞는 파일이나 폴더를 재귀적으로 검색한다",
        "syntax": "find 경로 [조건]",
        "options": [
          { "flag": "-name", "desc": "이름으로 검색 (와일드카드 사용 가능)" },
          { "flag": "-type", "desc": "유형 지정: d=폴더, f=파일" },
          { "flag": "-size", "desc": "크기 조건 (+100M = 100MB 초과)" },
          { "flag": "-mtime", "desc": "수정 시간 (-7 = 최근 7일 내)" },
          { "flag": "-delete", "desc": "찾은 파일을 삭제" }
        ],
        "examples": [
          { "code": "find . -name \"*.py\"", "desc": "현재 폴더 아래에서 .py 파일 모두 찾기" },
          { "code": "find . -type d -name \"models\"", "desc": "'models'라는 이름의 폴더만 검색" },
          { "code": "find . -size +100M", "desc": "100MB보다 큰 파일 찾기" },
          { "code": "find . -name \"*.log\" -delete", "desc": ".log 파일 찾아서 삭제" }
        ],
        "tip": "find 결과를 xargs와 조합하면 강력하다: find . -name '*.py' | xargs grep 'TODO'"
      },
      {
        "title": "which / whereis — 명령어 위치 찾기",
        "summary": "명령어의 실행 파일 위치를 찾는다",
        "syntax": "which 명령어 / whereis 명령어",
        "options": [],
        "examples": [
          { "code": "which python", "desc": "python 실행 파일의 위치" },
          { "code": "whereis cuda", "desc": "cuda 관련 바이너리, 소스, 매뉴얼 위치" }
        ],
        "tip": "which는 PATH에서 찾고, whereis는 더 넓은 범위에서 검색한다"
      }
    ]
  },
  {
    "level": "intermediate",
    "category": "파이프라인과 리다이렉션",
    "items": [
      {
        "title": "파이프 | — 명령어 연결",
        "summary": "왼쪽 명령어의 출력을 오른쪽 명령어의 입력으로 넘긴다",
        "syntax": "명령어A | 명령어B | 명령어C",
        "options": [],
        "examples": [
          { "code": "ps aux | grep python", "desc": "프로세스 목록에서 python 찾기" },
          { "code": "ls -la | grep \".py\"", "desc": "파일 목록에서 .py만 보기" },
          { "code": "cat log.txt | grep \"ERROR\" | wc -l", "desc": "로그에서 에러 줄 수 세기" },
          { "code": "ls -l | sort -k5 -n | head -n 10", "desc": "파일을 크기순 정렬해서 10개만" }
        ],
        "tip": "파이프는 리눅스의 핵심 철학 — 작은 도구를 연결해서 큰 작업을 수행"
      },
      {
        "title": "리다이렉션 — 출력을 파일로 저장",
        "summary": "명령어의 출력을 파일에 저장하거나 에러를 분리한다",
        "syntax": "명령어 > 파일 (덮어쓰기) / >> 파일 (이어쓰기)",
        "options": [
          { "flag": ">", "desc": "출력을 파일에 저장 (기존 내용 덮어쓰기)" },
          { "flag": ">>", "desc": "출력을 파일 끝에 추가 (이어쓰기)" },
          { "flag": "2>", "desc": "에러 메시지만 파일로 저장" },
          { "flag": "&>", "desc": "출력 + 에러 모두 파일로 저장" },
          { "flag": "/dev/null", "desc": "출력을 버린다 (아무것도 안 보고 싶을 때)" }
        ],
        "examples": [
          { "code": "echo \"hello\" > output.txt", "desc": "output.txt에 'hello' 저장 (덮어쓰기)" },
          { "code": "echo \"world\" >> output.txt", "desc": "output.txt 끝에 'world' 추가" },
          { "code": "python train.py 2> error.log", "desc": "에러만 error.log에 저장" },
          { "code": "python train.py > /dev/null 2>&1", "desc": "모든 출력 무시" }
        ],
        "tip": "> 는 파일을 덮어쓰므로 주의! 이어쓰려면 >> 사용"
      },
      {
        "title": "자주 쓰는 파이프 조합",
        "summary": "파이프와 다른 명령어를 조합한 실전 패턴",
        "syntax": null,
        "options": [],
        "examples": [
          { "code": "명령어 | less", "desc": "긴 출력을 스크롤하며 보기" },
          { "code": "명령어 | wc -l", "desc": "결과 개수 세기" },
          { "code": "명령어 | sort", "desc": "결과 정렬" },
          { "code": "명령어 | sort | uniq", "desc": "정렬 후 중복 제거" },
          { "code": "명령어 | awk '{print $2}'", "desc": "특정 열만 추출 (공백 기준 2번째 열)" }
        ],
        "tip": "sort | uniq로 중복 제거 시, 반드시 sort를 먼저 해야 한다 (uniq는 연속된 중복만 제거)"
      }
    ]
  },
  {
    "level": "intermediate",
    "category": "권한",
    "items": [
      {
        "title": "권한 읽는 법",
        "summary": "rwx 형식으로 파일의 읽기/쓰기/실행 권한을 표시한다",
        "syntax": "-rwxr-xr-- (소유자/그룹/기타)",
        "options": [
          { "flag": "r", "desc": "read — 읽기 권한" },
          { "flag": "w", "desc": "write — 쓰기 권한" },
          { "flag": "x", "desc": "execute — 실행 권한" }
        ],
        "examples": [
          { "code": "-rwxr-xr--", "desc": "소유자:rwx(읽기+쓰기+실행) 그룹:r-x(읽기+실행) 기타:r--(읽기만)" },
          { "code": "drwxr-xr-x", "desc": "d=폴더, 소유자: 전체 권한, 그룹/기타: 읽기+실행" }
        ],
        "tip": "맨 앞 글자: d=폴더(directory), -=일반 파일, l=심볼릭 링크"
      },
      {
        "title": "chmod — 권한 변경",
        "summary": "파일/폴더의 읽기, 쓰기, 실행 권한을 변경한다",
        "syntax": "chmod [옵션] 권한 파일",
        "options": [
          { "flag": "+x", "desc": "실행 권한 추가" },
          { "flag": "-x", "desc": "실행 권한 제거" },
          { "flag": "755", "desc": "숫자 모드: 소유자rwx(7), 그룹r-x(5), 기타r-x(5)" },
          { "flag": "644", "desc": "숫자 모드: 소유자rw-(6), 그룹r--(4), 기타r--(4)" }
        ],
        "examples": [
          { "code": "chmod +x script.sh", "desc": "스크립트에 실행 권한 추가 (실행 전 필수!)" },
          { "code": "chmod 755 script.sh", "desc": "소유자:rwx, 그룹:r-x, 기타:r-x" },
          { "code": "chmod 644 file.txt", "desc": "소유자:rw-, 그룹:r--, 기타:r--" }
        ],
        "tip": "숫자 계산: r=4, w=2, x=1 을 더한다. rwx = 4+2+1 = 7"
      },
      {
        "title": "chown — 소유자 변경",
        "summary": "파일/폴더의 소유자와 그룹을 변경한다",
        "syntax": "sudo chown [옵션] 소유자[:그룹] 파일",
        "options": [
          { "flag": "-R", "desc": "recursive — 폴더 안의 모든 파일까지" }
        ],
        "examples": [
          { "code": "sudo chown j.moon file.txt", "desc": "소유자 변경" },
          { "code": "sudo chown -R j.moon:staff my_folder/", "desc": "폴더 전체의 소유자+그룹 변경" }
        ],
        "tip": "chown은 보통 sudo(관리자 권한)가 필요하다"
      }
    ]
